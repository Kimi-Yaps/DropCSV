<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DropCSV — Upload, validate, edit and export CSV data with ease." />
    <title>@ViewData["Title"] - DropCSV</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DropCSV.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Csv" asp-action="Upload">
                    <div style="width:30px;height:30px;background:linear-gradient(135deg,#6c63ff,#48c774);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-filetype-csv text-white" style="font-size:0.85rem;"></i>
                    </div>
                    DropCSV
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Csv" asp-action="Upload">
                                <i class="bi bi-cloud-arrow-up me-1"></i>Upload CSV
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Csv" asp-action="Saved">
                                <i class="bi bi-database me-1"></i>Saved Data
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Csv" asp-action="Admin">
                                <i class="bi bi-shield-lock me-1"></i>Admin Dashboard
                            </a>
                        </li>
                    </ul>
                    <span class="navbar-text small" style="color:var(--text-muted);">
                        <i class="bi bi-shield-check me-1" style="color:var(--accent2);"></i>Secure Malware Scan Active
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 py-4" style="max-width:1400px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container-fluid px-4">
            &copy; 2026 DropCSV &mdash;
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
