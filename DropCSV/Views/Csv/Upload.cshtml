@model CsvUploadViewModel

@{
    ViewData["Title"] = "Drop CSV";
}

<div class="row justify-content-center g-4">
    <div class="col-12 col-xl-10">

        <!-- ── Upload Card ── -->
        <div class="card mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div style="width:38px;height:38px;background:linear-gradient(135deg,#6c63ff,#48c774);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-filetype-csv text-white" style="font-size:1.1rem;"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-700">Drop CSV</h5>
                        <p class="mb-0" style="font-size:0.8rem;color:var(--text-muted);">Upload, validate and edit your data</p>
                    </div>
                </div>

                <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Drag & Drop Zone -->
                    <div id="dropZone" class="p-5 text-center mb-3">
                        <i class="bi bi-cloud-arrow-up d-block mb-2"></i>
                        <p class="mb-1 fw-500">Drag &amp; drop your CSV file here</p>
                        <p class="small mb-0" style="color:var(--text-muted);">or click to browse — only .csv files accepted</p>
                        <input asp-for="CsvFile" type="file" class="d-none" accept=".csv" id="fileInput" />
                        <span asp-validation-for="CsvFile" class="text-danger d-block mt-2"></span>
                    </div>

                    <!-- Selected File Name -->
                    <div id="fileInfo" class="d-none mb-3">
                        <i class="bi bi-file-earmark-spreadsheet"></i>
                        <span id="fileName" class="fw-500 flex-grow-1"></span>
                        <span id="fileSize" class="small" style="color:var(--text-muted);"></span>
                        <button type="button" class="btn-close btn-close-white ms-2" onclick="clearFile()" style="opacity:0.5;"></button>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2" id="submitBtn" disabled>
                        <i class="bi bi-table me-2"></i>Load &amp; Display Table
                    </button>
                </form>
            </div>
        </div>

        <!-- ── Data Table Section ── -->
        @if (Model.HasData)
        {
            <!-- Stats row -->
            <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
                <span class="stat-pill"><i class="bi bi-grid-3x3"></i> <span class="num">@Model.Rows.Count</span> rows</span>
                <span class="stat-pill"><i class="bi bi-layout-three-columns"></i> <span class="num">@Model.Headers.Count</span> columns</span>
                <span class="stat-pill" id="selectedPill" style="display:none!important;">
                    <i class="bi bi-check2-square" style="color:var(--accent);"></i>
                    <span class="num" id="selectedCount">0</span> selected
                </span>
                <span class="stat-pill" id="invalidPill" style="color:var(--accent-danger);border-color:rgba(255,77,106,0.3);">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span class="num" id="invalidCount">0</span> issues
                </span>
            </div>

            <!-- Bulk action toolbar -->
            <div id="bulkToolbar" class="hidden mb-3">
                <span style="font-size:0.85rem;color:var(--text-muted);">
                    <span id="toolbarCount">0</span> row(s) selected
                </span>
                <div class="d-flex gap-2 ms-auto flex-wrap">
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteSelectedRows()">
                        <i class="bi bi-trash me-1"></i>Delete Selected
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="clearSelection()">
                        <i class="bi bi-x me-1"></i>Clear
                    </button>
                </div>
            </div>

            <!-- ── Search Bar ── -->
            <div class="search-bar-card mb-3">
                <div class="search-bar-inner">
                    <!-- Icon -->
                    <div class="search-bar-icon">
                        <i class="bi bi-search" id="searchIcon"></i>
                    </div>

                    <!-- Input -->
                    <input
                        type="text"
                        id="mainSearch"
                        class="search-bar-input"
                        placeholder="Search across all columns…"
                        autocomplete="off"
                        spellcheck="false"
                        oninput="onSearchInput(this.value)"
                        onkeydown="onSearchKey(event)" />

                    <!-- Column filter -->
                    <div class="search-bar-divider"></div>
                    <div class="search-col-wrap">
                        <i class="bi bi-funnel" style="color:var(--text-muted);font-size:0.8rem;"></i>
                        <select id="searchCol" class="search-col-select" onchange="onSearchInput(document.getElementById('mainSearch').value)" title="Filter by column">
                            <option value="all">All columns</option>
                            @foreach (var header in Model.Headers)
                            {
                                <option value="@header">@header</option>
                            }
                        </select>
                    </div>

                    <!-- Clear button -->
                    <button class="search-bar-clear d-none" id="searchClear" onclick="clearSearch()" title="Clear search">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <!-- Result info bar -->
                <div class="search-bar-results" id="searchResults" style="display:none;">
                    <span id="searchMatchText"></span>
                    <span class="search-shortcut"><kbd>↑</kbd><kbd>↓</kbd> navigate &nbsp; <kbd>Esc</kbd> clear</span>
                </div>
            </div>

            <!-- Table Card -->
            <div class="card">
                <div class="card-header d-flex flex-wrap align-items-center gap-2">
                    <div class="d-flex align-items-center gap-2 me-auto">
                        <i class="bi bi-table" style="color:var(--accent);"></i>
                        <span class="fw-600">CSV Data</span>
                        <span class="badge" id="matchBadge" style="background:rgba(108,99,255,0.2);color:var(--accent);display:none;"></span>
                    </div>

                    <!-- Validate toggle -->
                    <button class="btn btn-sm btn-outline-secondary" id="validateBtn" onclick="toggleValidation()">
                        <i class="bi bi-shield-check me-1"></i>Validate
                    </button>

                    <!-- Export -->
                    <button class="btn btn-sm btn-success" onclick="downloadCsv()">
                        <i class="bi bi-download me-1"></i>Export CSV
                    </button>
                </div>

                <!-- Validation Panel (collapsible) -->
                <div id="validationPanel" class="d-none px-3 pt-3 pb-1" style="border-bottom:1px solid var(--border);">
                    <p class="mb-2 fw-600 small" style="color:var(--text-muted);text-transform:uppercase;letter-spacing:0.7px;">
                        <i class="bi bi-shield-check me-1"></i>Validation Results
                    </p>
                    <div id="validationItems"></div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-bordered mb-0 align-middle" id="csvTable">
                            <thead>
                                <tr>
                                    <!-- Select-all checkbox -->
                                    <th class="text-center" style="width:42px;">
                                        <input class="form-check-input" type="checkbox" id="selectAll" title="Select all" />
                                    </th>
                                    <!-- Row number -->
                                    <th class="text-center" style="width:48px;color:var(--text-muted);">#</th>
                                    @foreach (var header in Model.Headers)
                                    {
                                        <th>@header</th>
                                    }
                                    <!-- Actions -->
                                    <th class="text-center" style="width:64px;">Act.</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody">
                                @for (int i = 0; i < Model.Rows.Count; i++)
                                {
                                    <tr data-row="@i">
                                        <!-- Checkbox -->
                                        <td class="text-center">
                                            <input class="form-check-input row-check" type="checkbox" data-row="@i" onchange="onRowCheck(this)" />
                                        </td>
                                        <!-- Row number -->
                                        <td class="text-center text-muted small">@(i + 1)</td>
                                        @for (int j = 0; j < Model.Rows[i].Count; j++)
                                        {
                                            <td data-col="@j" data-original="@Model.Rows[i][j]">
                                                <span class="editable-cell"
                                                      contenteditable="false"
                                                      data-row="@i"
                                                      data-col="@j"
                                                      onblur="onCellBlur(this)"
                                                      oninput="onCellInput(this)"
                                                      title="Click Edit to modify">@Model.Rows[i][j]</span>
                                            </td>
                                        }
                                        <!-- Edit / Save / Delete -->
                                        <td class="text-center">
                                            <div class="d-flex gap-1 justify-content-center">
                                                <button class="btn btn-sm btn-icon btn-outline-secondary edit-btn"
                                                        title="Edit row" onclick="startEdit(this, @i)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-icon btn-warning save-btn d-none"
                                                        title="Save row" onclick="saveEdit(this, @i)">
                                                    <i class="bi bi-check2"></i>
                                                </button>
                                                <button class="btn btn-sm btn-icon btn-outline-danger"
                                                        title="Delete row" onclick="deleteRow(this)">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Table footer -->
                <div class="card-footer d-flex justify-content-between align-items-center py-2 px-3"
                     style="background:var(--bg-card2);border-top:1px solid var(--border);font-size:0.82rem;color:var(--text-muted);">
                    <span id="visibleCount">Showing @Model.Rows.Count of @Model.Rows.Count rows</span>
                    <span>Click <i class="bi bi-pencil" style="color:var(--accent);"></i> on a row to edit cells inline</span>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
    /* ===================================================
       DropCSV — UI Logic
       =================================================== */

    // ── Upload / Drop Zone ──────────────────────────────
    const dropZone  = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const fileInfo  = document.getElementById('fileInfo');
    const fileNameEl= document.getElementById('fileName');
    const fileSizeEl= document.getElementById('fileSize');
    const submitBtn = document.getElementById('submitBtn');

    dropZone?.addEventListener('click', () => fileInput.click());

    fileInput?.addEventListener('change', function () {
        if (this.files.length > 0) showFile(this.files[0]);
    });

    dropZone?.addEventListener('dragover', e => {
        e.preventDefault();
        dropZone.classList.add('drag-over');
    });
    dropZone?.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone?.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        const files = e.dataTransfer.files;
        if (files.length > 0 && files[0].name.endsWith('.csv')) {
            const dt = new DataTransfer();
            dt.items.add(files[0]);
            fileInput.files = dt.files;
            showFile(files[0]);
        }
    });

    function showFile(file) {
        fileNameEl.textContent = file.name;
        fileSizeEl.textContent = formatBytes(file.size);
        fileInfo.classList.remove('d-none');
        submitBtn.disabled = false;
    }

    function clearFile() {
        fileInput.value = '';
        fileInfo.classList.add('d-none');
        submitBtn.disabled = true;
    }

    function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(2) + ' MB';
    }

    // ── Checkbox / Row Selection ────────────────────────
    const selectAllCb  = document.getElementById('selectAll');
    const bulkToolbar  = document.getElementById('bulkToolbar');
    const toolbarCount = document.getElementById('toolbarCount');
    const selectedPill = document.getElementById('selectedPill');
    const selectedCountEl = document.getElementById('selectedCount');

    selectAllCb?.addEventListener('change', function () {
        document.querySelectorAll('.row-check:not(.d-none)').forEach(cb => {
            cb.checked = this.checked;
            cb.closest('tr').classList.toggle('row-selected', this.checked);
        });
        updateSelection();
    });

    function onRowCheck(cb) {
        cb.closest('tr').classList.toggle('row-selected', cb.checked);
        const all = document.querySelectorAll('.row-check:not([style*="display: none"])');
        const checked = document.querySelectorAll('.row-check:checked');
        if (selectAllCb) selectAllCb.indeterminate = checked.length > 0 && checked.length < all.length;
        if (selectAllCb) selectAllCb.checked = checked.length === all.length && all.length > 0;
        updateSelection();
    }

    function updateSelection() {
        const count = document.querySelectorAll('.row-check:checked').length;
        if (toolbarCount) toolbarCount.textContent = count;
        if (selectedCountEl) selectedCountEl.textContent = count;
        if (bulkToolbar) bulkToolbar.classList.toggle('hidden', count === 0);
        if (selectedPill) selectedPill.style.display = count > 0 ? '' : 'none!important';
    }

    function clearSelection() {
        document.querySelectorAll('.row-check').forEach(cb => {
            cb.checked = false;
            cb.closest('tr').classList.remove('row-selected');
        });
        if (selectAllCb) { selectAllCb.checked = false; selectAllCb.indeterminate = false; }
        updateSelection();
    }

    function deleteSelectedRows() {
        if (!confirm('Delete selected rows?')) return;
        document.querySelectorAll('.row-check:checked').forEach(cb => cb.closest('tr').remove());
        clearSelection();
        reindexRows();
        runValidation();
    }

    // ── Inline Edit ─────────────────────────────────────
    function startEdit(btn, rowIdx) {
        const tr = btn.closest('tr');
        tr.querySelectorAll('.editable-cell').forEach(el => {
            el.contentEditable = 'true';
            el.classList.add('editing');
        });
        btn.classList.add('d-none');
        tr.querySelector('.save-btn').classList.remove('d-none');
        tr.querySelector('.editable-cell').focus();
    }

    function saveEdit(btn, rowIdx) {
        const tr = btn.closest('tr');
        tr.querySelectorAll('.editable-cell').forEach(el => {
            el.contentEditable = 'false';
            el.classList.remove('editing');
            el.closest('td').dataset.original = el.textContent;
        });
        btn.classList.add('d-none');
        tr.querySelector('.edit-btn').classList.remove('d-none');
        runValidation();
    }

    function onCellBlur(el) { /* validation on blur */ runCellValidation(el); }
    function onCellInput(el) { runCellValidation(el); }

    function runCellValidation(el) {
        const td = el.closest('td');
        const val = el.textContent.trim();
        td.classList.remove('cell-invalid', 'cell-empty');
        if (val === '') td.classList.add('cell-empty');
    }

    // ── Delete single row ───────────────────────────────
    function deleteRow(btn) {
        if (!confirm('Delete this row?')) return;
        btn.closest('tr').remove();
        reindexRows();
        runValidation();
    }

    function reindexRows() {
        document.querySelectorAll('#tableBody tr').forEach((tr, i) => {
            const numCell = tr.querySelector('td:nth-child(2)');
            if (numCell) numCell.textContent = i + 1;
        });
        updateVisibleCount();
    }

    // ── Search / Filter ──────────────────────────────────
    let currentMatchIndex = -1;
    let matchedRows = [];
    const HIGHLIGHT_CLASS = 'search-highlight';
    const HIGHLIGHT_ACTIVE = 'search-highlight-active';

    function getColIndex(colName) {
        if (colName === 'all') return -1;
        let idx = -1;
        document.querySelectorAll('#csvTable thead th').forEach((th, i) => {
            if (i >= 2 && th.textContent.trim() === colName) idx = i - 2; // offset: cb + # cols
        });
        return idx;
    }

    function onSearchInput(query) {
        const q = query.trim();
        const colName = document.getElementById('searchCol')?.value || 'all';
        const colIdx = getColIndex(colName);
        const clearBtn = document.getElementById('searchClear');
        const resultsBar = document.getElementById('searchResults');
        const matchBadge = document.getElementById('matchBadge');
        const icon = document.getElementById('searchIcon');

        // Show/hide clear button
        if (clearBtn) clearBtn.classList.toggle('d-none', q === '');
        if (icon) icon.className = q ? 'bi bi-search text-accent' : 'bi bi-search';

        // Remove old highlights
        document.querySelectorAll('.' + HIGHLIGHT_CLASS).forEach(el => {
            el.outerHTML = el.textContent;
        });
        matchedRows = [];
        currentMatchIndex = -1;

        if (q === '') {
            document.querySelectorAll('#tableBody tr').forEach(tr => tr.style.display = '');
            if (resultsBar) resultsBar.style.display = 'none';
            if (matchBadge) matchBadge.style.display = 'none';
            updateVisibleCount();
            return;
        }

        const ql = q.toLowerCase();
        let visible = 0;

        document.querySelectorAll('#tableBody tr').forEach(tr => {
            const cells = tr.querySelectorAll('.editable-cell');
            let rowMatches = false;

            cells.forEach((cell, ci) => {
                if (colIdx !== -1 && ci !== colIdx) return;
                const text = cell.textContent;
                const lower = text.toLowerCase();
                const pos = lower.indexOf(ql);
                if (pos !== -1) {
                    rowMatches = true;
                    // Highlight matched text
                    const before = text.slice(0, pos);
                    const match  = text.slice(pos, pos + q.length);
                    const after  = text.slice(pos + q.length);
                    cell.innerHTML =
                        escHtml(before) +
                        `<mark class="${HIGHLIGHT_CLASS}">${escHtml(match)}</mark>` +
                        escHtml(after);
                }
            });

            tr.style.display = rowMatches ? '' : 'none';
            if (rowMatches) { visible++; matchedRows.push(tr); }
        });

        // Update result info
        const matchText = document.getElementById('searchMatchText');
        if (matchText) matchText.innerHTML =
            `<i class="bi bi-search me-1"></i> <b>${visible}</b> row${visible !== 1 ? 's' : ''} matched <span style="color:var(--text-muted)">"${escHtml(q)}"</span>` +
            (colIdx !== -1 ? ` <span class="badge" style="background:rgba(108,99,255,0.18);color:var(--accent);">${colName}</span>` : '');
        if (resultsBar) resultsBar.style.display = visible > 0 || q ? 'flex' : 'none';
        if (matchBadge) { matchBadge.textContent = visible + ' match' + (visible !== 1 ? 'es' : ''); matchBadge.style.display = ''; }

        // Scroll first match into view
        if (matchedRows.length > 0) {
            currentMatchIndex = 0;
            highlightActiveRow();
        }
        updateVisibleCount(visible);
    }

    function onSearchKey(e) {
        if (e.key === 'Escape') { clearSearch(); return; }
        if (e.key === 'ArrowDown') { e.preventDefault(); stepMatch(1); }
        if (e.key === 'ArrowUp')   { e.preventDefault(); stepMatch(-1); }
    }

    function stepMatch(dir) {
        if (!matchedRows.length) return;
        matchedRows[currentMatchIndex]?.classList.remove('search-row-active');
        currentMatchIndex = (currentMatchIndex + dir + matchedRows.length) % matchedRows.length;
        highlightActiveRow();
    }

    function highlightActiveRow() {
        matchedRows.forEach(tr => tr.classList.remove('search-row-active'));
        const active = matchedRows[currentMatchIndex];
        if (active) {
            active.classList.add('search-row-active');
            active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
    }

    function clearSearch() {
        const input = document.getElementById('mainSearch');
        if (input) { input.value = ''; input.focus(); }
        onSearchInput('');
    }

    function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function updateVisibleCount(vis) {
        const total = document.querySelectorAll('#tableBody tr').length;
        const shown = vis !== undefined ? vis : total;
        const el = document.getElementById('visibleCount');
        if (el) el.textContent = `Showing ${shown} of ${total} rows`;
    }

    // Legacy alias (used by old inline calls, kept for safety)
    function filterTable(q) { onSearchInput(q); }

    // ── Data Validation ──────────────────────────────────
    let validationVisible = false;

    function toggleValidation() {
        validationVisible = !validationVisible;
        const panel = document.getElementById('validationPanel');
        if (validationVisible) {
            panel.classList.remove('d-none');
            runValidation();
        } else {
            panel.classList.add('d-none');
            // Clear highlights
            document.querySelectorAll('td.cell-empty, td.cell-invalid').forEach(td => {
                td.classList.remove('cell-empty', 'cell-invalid');
            });
        }
    }

    function runValidation() {
        const items = [];
        let issueCount = 0;
        const headers = [];
        document.querySelectorAll('#csvTable thead th').forEach((th, i) => {
            if (i >= 2 && i < document.querySelectorAll('#csvTable thead th').length - 1)
                headers.push(th.textContent.trim());
        });

        document.querySelectorAll('#tableBody tr').forEach((tr, rowIdx) => {
            const cells = tr.querySelectorAll('td .editable-cell');
            cells.forEach((el, colIdx) => {
                const td = el.closest('td');
                const val = el.textContent.trim();
                const colName = headers[colIdx] || `Col ${colIdx + 1}`;
                td.classList.remove('cell-empty', 'cell-invalid');

                if (val === '') {
                    td.classList.add('cell-empty');
                    items.push({ type: 'warn', msg: `Row ${rowIdx + 1}, <b>${colName}</b>: empty value` });
                    issueCount++;
                }
            });
        });

        // Update invalid count badge
        const invalidCountEl = document.getElementById('invalidCount');
        if (invalidCountEl) invalidCountEl.textContent = issueCount;

        // Render panel
        const container = document.getElementById('validationItems');
        if (!container) return;
        container.innerHTML = '';

        if (items.length === 0) {
            container.innerHTML = `<div class="val-item ok"><i class="bi bi-check-circle-fill"></i> All cells have values — no issues found.</div>`;
        } else {
            items.forEach(item => {
                const div = document.createElement('div');
                div.className = `val-item ${item.type}`;
                div.innerHTML = `<i class="bi bi-${item.type === 'warn' ? 'exclamation-circle' : 'x-circle-fill'}"></i> ${item.msg}`;
                container.appendChild(div);
            });
        }
        updateVisibleCount();
    }

    // ── Export CSV ───────────────────────────────────────
    function downloadCsv() {
        const table = document.getElementById('csvTable');
        const csv = [];

        const headers = [];
        table.querySelectorAll('thead th').forEach((th, i) => {
            if (i >= 2 && i < table.querySelectorAll('thead th').length - 1)
                headers.push('"' + th.innerText.replace(/"/g, '""') + '"');
        });
        csv.push(headers.join(','));

        table.querySelectorAll('#tableBody tr').forEach(tr => {
            if (tr.style.display === 'none') return;
            const row = [];
            tr.querySelectorAll('.editable-cell').forEach(el => {
                row.push('"' + el.textContent.replace(/"/g, '""') + '"');
            });
            if (row.length) csv.push(row.join(','));
        });

        const blob = new Blob([csv.join('\n')], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'data_export.csv';
        a.click();
        URL.revokeObjectURL(url);
    }

    // ── Init ─────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        updateVisibleCount();
        // Show initial issue count
        let issues = 0;
        document.querySelectorAll('#tableBody tr').forEach(tr => {
            tr.querySelectorAll('.editable-cell').forEach(el => {
                if (el.textContent.trim() === '') issues++;
            });
        });
        const el = document.getElementById('invalidCount');
        if (el) el.textContent = issues;
    });
    </script>
}