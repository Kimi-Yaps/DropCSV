@model SavedDataViewModel

@{
    ViewData["Title"] = "Saved CSV Data";
}

<div class="row justify-content-center g-4">
    <div class="col-12 col-xl-11">

        <!-- ── Title Block ── -->
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <div class="d-flex align-items-center gap-2">
                <div style="width:38px;height:38px;background:linear-gradient(135deg,#36b9cc,#2e59d9);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-database text-white" style="font-size:1.1rem;"></i>
                </div>
                <div>
                    <h5 class="mb-0 fw-700">Saved CSV Data</h5>
                    <p class="mb-0 text-muted" style="font-size:0.8rem;">
                        @if (Model.HasData)
                        {
                            <text>Loaded from MySQL database &mdash; Saved at @Model.SavedAt.ToString("yyyy-MM-dd HH:mm:ss")</text>
                        }
                        else
                        {
                            <text>No saved CSV data found in the database.</text>
                        }
                    </p>
                </div>
            </div>

            @if (Model.HasData)
            {
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <button class="btn btn-outline-warning btn-sm fw-600" onclick="toggleDuplicatePanel()">
                        <i class="bi bi-search-heart me-1"></i>Clean Duplicates
                    </button>
                    <form asp-action="ClearSaved" method="post" onsubmit="return confirm('Are you sure you want to clear all saved records from the database?');" class="mb-0">
                        <button type="submit" class="btn btn-outline-danger btn-sm fw-600">
                            <i class="bi bi-trash3 me-1"></i>Clear Table
                        </button>
                    </form>
                    <a asp-action="Upload" class="btn btn-primary btn-sm fw-600">
                        <i class="bi bi-cloud-arrow-up me-1"></i>Upload New CSV
                    </a>
                </div>
            }
        </div>

        @if (Model.HasData)
        {
            <!-- ── Duplicate Cleaner Panel (Collapsible) ── -->
            <div id="duplicatePanel" class="card mb-4 border-warning d-none" style="background:var(--bg-card); transition:var(--transition);">
                <div class="card-header bg-warning-light py-3 d-flex align-items-center justify-content-between" style="background:rgba(232,147,10,0.06);">
                    <h6 class="mb-0 fw-700 text-warning"><i class="bi bi-search-heart-fill me-2"></i>Database Duplicate Scanner</h6>
                    <button type="button" class="btn-close" onclick="toggleDuplicatePanel()" style="font-size:0.75rem;"></button>
                </div>
                <div class="card-body p-4">
                    <p class="small text-muted mb-3">
                        Scan the active database records for duplicates. Check the columns you want to use for matching (e.g. comparing email or ID). Leave all columns checked to find exact row duplicates.
                    </p>
                    
                    <!-- Compare Column Selectors -->
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var col in Model.Headers)
                        {
                            <div class="form-check form-check-inline p-2 border rounded cursor-pointer border-primary" 
                                 style="background: var(--bg-card2);" onclick="toggleDbCheck('dbcol_@col')">
                                <input class="form-check-input db-col-select" type="checkbox" value="@col" id="dbcol_@col" checked onclick="event.stopPropagation();" />
                                <label class="form-check-label fw-500 cursor-pointer mb-0" for="dbcol_@col" onclick="event.stopPropagation();">@col</label>
                            </div>
                        }
                    </div>

                    <button class="btn btn-warning btn-sm fw-600" onclick="scanDatabaseDuplicates()">
                        <i class="bi bi-cpu me-1"></i>Scan &amp; Identify Duplicates
                    </button>

                    <!-- Scan Results Area -->
                    <div id="scanResults" class="mt-4 d-none">
                        <hr />
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <span class="fw-700 text-uppercase small text-muted" id="scanResultsSummary"></span>
                            <button class="btn btn-danger btn-sm fw-600" id="deleteDuplicatesBtn" onclick="deleteSelectedDuplicates()" disabled>
                                <i class="bi bi-trash-fill me-1"></i>Delete Selected Duplicates
                            </button>
                        </div>
                        <div id="duplicateGroupsContainer" class="d-flex flex-column gap-3"></div>
                    </div>
                </div>
            </div>

            <!-- Stats Bar -->
            <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
                <span class="stat-pill"><i class="bi bi-grid-3x3"></i> <span class="num" id="totalRowCount">@Model.Rows.Count</span> rows</span>
                <span class="stat-pill"><i class="bi bi-layout-three-columns"></i> <span class="num">@Model.Headers.Count</span> columns</span>
                <span class="stat-pill" id="selectedPill" style="display:none!important;">
                    <i class="bi bi-check2-square" style="color:var(--accent);"></i>
                    <span class="num" id="selectedCount">0</span> selected
                </span>
                <span class="stat-pill" id="invalidPill" style="color:var(--accent-danger);border-color:rgba(255,77,106,0.3);">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span class="num" id="invalidCount">0</span> issues
                </span>
            </div>

            <!-- Bulk Actions Toolbar -->
            <div id="bulkToolbar" class="hidden mb-3">
                <span style="font-size:0.85rem;color:var(--text-muted);">
                    <span id="toolbarCount">0</span> row(s) selected
                </span>
                <div class="d-flex gap-2 ms-auto flex-wrap">
                    <button class="btn btn-sm btn-outline-danger fw-600" onclick="deleteSelectedRows()">
                        <i class="bi bi-trash me-1"></i>Delete Selected
                    </button>
                    <button class="btn btn-sm btn-outline-secondary fw-600" onclick="clearSelection()">
                        <i class="bi bi-x me-1"></i>Clear Selection
                    </button>
                </div>
            </div>

            <!-- ── Search & Filter Toolbar ── -->
            <div class="search-bar-card mb-3">
                <div class="search-bar-inner">
                    <div class="search-bar-icon">
                        <i class="bi bi-search" id="searchIcon"></i>
                    </div>
                    <input
                        type="text"
                        id="mainSearch"
                        class="search-bar-input"
                        placeholder="Search across all columns…"
                        autocomplete="off"
                        spellcheck="false"
                        oninput="onSearchInput(this.value)"
                        onkeydown="onSearchKey(event)" />
                    
                    <div class="search-bar-divider"></div>
                    <div class="search-col-wrap">
                        <i class="bi bi-funnel" style="color:var(--text-muted);font-size:0.8rem;"></i>
                        <select id="searchCol" class="search-col-select" onchange="onSearchInput(document.getElementById('mainSearch').value)" title="Filter by column">
                            <option value="all">All columns</option>
                            @foreach (var header in Model.Headers)
                            {
                                <option value="@header">@header</option>
                            }
                        </select>
                    </div>

                    <button class="search-bar-clear d-none" id="searchClear" onclick="clearSearch()" title="Clear search">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <!-- Search Results Nav -->
                <div class="search-bar-results" id="searchResults" style="display:none;">
                    <span id="searchMatchText"></span>
                    <span class="search-shortcut"><kbd>↑</kbd><kbd>↓</kbd> navigate &nbsp; <kbd>Esc</kbd> clear</span>
                </div>
            </div>

            <!-- Table Card -->
            <div class="card mb-4 shadow">
                <div class="card-header d-flex flex-wrap align-items-center gap-2">
                    <div class="d-flex align-items-center gap-2 me-auto">
                        <i class="bi bi-table" style="color:var(--accent-info);"></i>
                        <span class="fw-600">Database CSV Viewer</span>
                        <span class="badge" id="matchBadge" style="background:rgba(108,99,255,0.2);color:var(--accent);display:none;"></span>
                    </div>

                    <button class="btn btn-sm btn-outline-secondary" id="validateBtn" onclick="toggleValidation()">
                        <i class="bi bi-shield-check me-1"></i>Validate
                    </button>

                    <!-- Add Row Trigger -->
                    <button class="btn btn-sm btn-primary fw-600" onclick="startAddNewRow()">
                        <i class="bi bi-plus-lg me-1"></i>Add Row
                    </button>

                    <button class="btn btn-success btn-sm fw-600" onclick="downloadCsv()">
                        <i class="bi bi-download me-1"></i>Export CSV
                    </button>
                </div>

                <!-- Validation Collapsible Panel -->
                <div id="validationPanel" class="d-none px-3 pt-3 pb-1" style="border-bottom:1px solid var(--border);">
                    <p class="mb-2 fw-600 small" style="color:var(--text-muted);text-transform:uppercase;letter-spacing:0.7px;">
                        <i class="bi bi-shield-check me-1"></i>Validation Results
                    </p>
                    <div id="validationItems"></div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-bordered mb-0 align-middle" id="savedTable">
                            <thead>
                                <tr>
                                    <!-- Bulk Selection Checkbox -->
                                    <th class="text-center" style="width:42px;">
                                        <input class="form-check-input" type="checkbox" id="selectAll" title="Select all" />
                                    </th>
                                    <th class="text-center" style="width:55px;color:var(--text-muted);">#</th>
                                    @foreach (var header in Model.Headers)
                                    {
                                        <th>@header</th>
                                    }
                                    <th class="text-center" style="width:100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody">
                                @for (int i = 0; i < Model.Rows.Count; i++)
                                {
                                    <tr data-row="@i">
                                        <!-- Row Checkbox -->
                                        <td class="text-center">
                                            <input class="form-check-input row-check" type="checkbox" data-row="@i" onchange="onRowCheck(this)" />
                                        </td>
                                        <!-- Index -->
                                        <td class="text-center text-muted small">@(i + 1)</td>
                                        <!-- Columns -->
                                        @for (int j = 0; j < Model.Rows[i].Count; j++)
                                        {
                                            <td data-col="@j" data-original="@Model.Rows[i][j]">
                                                <span class="editable-cell"
                                                      contenteditable="false"
                                                      data-row="@i"
                                                      data-col="@j"
                                                      onblur="onCellBlur(this)"
                                                      oninput="onCellInput(this)">@Model.Rows[i][j]</span>
                                            </td>
                                        }
                                        <!-- Action Buttons -->
                                        <td class="text-center">
                                            <div class="d-flex gap-1 justify-content-center">
                                                <button class="btn btn-xs btn-icon btn-outline-secondary edit-btn"
                                                        title="Edit Row" onclick="startEdit(this, @i)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-xs btn-icon btn-warning save-btn d-none"
                                                        title="Save Changes" onclick="saveEdit(this, @i)">
                                                    <i class="bi bi-check2"></i>
                                                </button>
                                                <button class="btn btn-xs btn-icon btn-outline-danger"
                                                        title="Delete Row" onclick="deleteRow(this, @i)">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center py-2 px-3">
                    <span id="visibleCount">Showing @Model.Rows.Count of @Model.Rows.Count rows</span>
                    <span>MySQL Database Source: <code class="text-accent">dropcsv_db.saved_csv</code></span>
                </div>
            </div>
        }
        else
        {
            <div class="card text-center py-5 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-database-exclamation text-muted d-block mb-3" style="font-size:3rem;"></i>
                    <h5 class="fw-700">Database is Empty</h5>
                    <p class="text-muted mx-auto" style="max-width:400px; font-size:0.9rem;">
                        There is no CSV data saved in the database yet. Upload a CSV file to save it and manage records.
                    </p>
                    <a asp-action="Upload" class="btn btn-primary mt-2">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Go to Upload
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
    /* ===================================================
       DropCSV — Saved Data Page & CRUD Logic
       =================================================== */

    // ── Checkbox / Row Selection ────────────────────────
    const selectAllCb  = document.getElementById('selectAll');
    const bulkToolbar  = document.getElementById('bulkToolbar');
    const toolbarCount = document.getElementById('toolbarCount');
    const selectedPill = document.getElementById('selectedPill');
    const selectedCountEl = document.getElementById('selectedCount');

    selectAllCb?.addEventListener('change', function () {
        document.querySelectorAll('.row-check').forEach(cb => {
            if (cb.closest('tr').style.display !== 'none') {
                cb.checked = this.checked;
                cb.closest('tr').classList.toggle('row-selected', this.checked);
            }
        });
        updateSelection();
    });

    function onRowCheck(cb) {
        cb.closest('tr').classList.toggle('row-selected', cb.checked);
        const all = document.querySelectorAll('.row-check:not([style*="display: none"])');
        const checked = document.querySelectorAll('.row-check:checked');
        if (selectAllCb) selectAllCb.indeterminate = checked.length > 0 && checked.length < all.length;
        if (selectAllCb) selectAllCb.checked = checked.length === all.length && all.length > 0;
        updateSelection();
    }

    function updateSelection() {
        const count = document.querySelectorAll('.row-check:checked').length;
        if (toolbarCount) toolbarCount.textContent = count;
        if (selectedCountEl) selectedCountEl.textContent = count;
        if (bulkToolbar) bulkToolbar.classList.toggle('hidden', count === 0);
        if (selectedPill) selectedPill.style.display = count > 0 ? '' : 'none!important';
    }

    function clearSelection() {
        document.querySelectorAll('.row-check').forEach(cb => {
            cb.checked = false;
            cb.closest('tr').classList.remove('row-selected');
        });
        if (selectAllCb) { selectAllCb.checked = false; selectAllCb.indeterminate = false; }
        updateSelection();
    }

    // ── CRUD: Add New Row Inline ────────────────────────
    let isAddingRow = false;

    function startAddNewRow() {
        if (isAddingRow) return;
        isAddingRow = true;

        const tableBody = document.getElementById('tableBody');
        if (!tableBody) return;

        // Calculate columns count
        const headersCount = document.querySelectorAll('#savedTable thead th').length - 3; // subtract checkbox, #, and actions

        const tr = document.createElement('tr');
        tr.id = 'newRowTemplate';
        tr.className = 'table-info';

        // Checkbox placeholder
        let html = '<td class="text-center"><i class="bi bi-plus-circle text-primary"></i></td>';
        // # placeholder
        html += '<td class="text-center text-muted small">*</td>';

        // Columns
        for (let j = 0; j < headersCount; j++) {
            html += `<td>
                <span class="editable-cell editing" contenteditable="true" data-new-col="${j}" onblur="onCellBlur(this)"></span>
            </td>`;
        }

        // Actions
        html += `<td class="text-center">
            <div class="d-flex gap-1 justify-content-center">
                <button class="btn btn-xs btn-icon btn-success" title="Save New Row" onclick="saveNewRow(this)">
                    <i class="bi bi-check2"></i>
                </button>
                <button class="btn btn-xs btn-icon btn-outline-danger" title="Cancel" onclick="cancelAddNewRow()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </td>`;

        tr.innerHTML = html;
        tableBody.insertBefore(tr, tableBody.firstChild);
        tr.querySelector('.editable-cell').focus();
    }

    function cancelAddNewRow() {
        const row = document.getElementById('newRowTemplate');
        if (row) row.remove();
        isAddingRow = false;
        runValidation();
    }

    function saveNewRow(btn) {
        const tr = btn.closest('tr');
        const cells = tr.querySelectorAll('[data-new-col]');
        const rowData = [];
        let hasErrors = false;

        cells.forEach(el => {
            const val = el.textContent.trim();
            rowData.push(val);
            if (val === '') {
                el.closest('td').classList.add('cell-empty');
                hasErrors = true;
            }
        });

        // Run validation check before sending
        if (hasErrors) {
            alert('Please fill out all cells in the row before saving.');
            return;
        }

        const payload = { RowData: rowData };

        fetch('@Url.Action("AddRow", "Csv")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) return response.json();
            throw new Error('Failed to add record to database.');
        })
        .then(data => {
            window.location.reload();
        })
        .catch(err => {
            alert('Error adding row: ' + err.message);
        });
    }

    // ── CRUD: Edit/Update Row ───────────────────────────
    function startEdit(btn, rowIdx) {
        const tr = btn.closest('tr');
        tr.querySelectorAll('.editable-cell').forEach(el => {
            el.contentEditable = 'true';
            el.classList.add('editing');
        });
        btn.classList.add('d-none');
        tr.querySelector('.save-btn').classList.remove('d-none');
        tr.querySelector('.editable-cell').focus();
    }

    function saveEdit(btn, rowIdx) {
        const tr = btn.closest('tr');
        const cells = tr.querySelectorAll('.editable-cell');
        const rowData = [];
        let hasErrors = false;

        cells.forEach(el => {
            const val = el.textContent.trim();
            rowData.push(val);
            if (val === '') {
                el.closest('td').classList.add('cell-empty');
                hasErrors = true;
            }
            if (el.closest('td').classList.contains('cell-invalid')) {
                hasErrors = true;
            }
        });

        if (hasErrors) {
            alert('Please fix all validation issues and empty cells before saving.');
            return;
        }

        const payload = {
            RowIndex: rowIdx,
            RowData: rowData
        };

        fetch('@Url.Action("UpdateRow", "Csv")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) return response.json();
            throw new Error('Failed to update row.');
        })
        .then(data => {
            // Success
            cells.forEach(el => {
                el.contentEditable = 'false';
                el.classList.remove('editing');
                el.closest('td').dataset.original = el.textContent;
            });
            btn.classList.add('d-none');
            tr.querySelector('.edit-btn').classList.remove('d-none');
            runValidation();
        })
        .catch(err => {
            alert('Error saving row: ' + err.message);
        });
    }

    // ── CRUD: Delete Row ────────────────────────────────
    function deleteRow(btn, rowIdx) {
        if (!confirm('Are you sure you want to delete this row from the database?')) return;

        const payload = { RowIndex: rowIdx };

        fetch('@Url.Action("DeleteRow", "Csv")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) return response.json();
            throw new Error('Failed to delete row.');
        })
        .then(data => {
            window.location.reload();
        })
        .catch(err => {
            alert('Error deleting row: ' + err.message);
        });
    }

    // ── CRUD: Bulk Delete Rows ──────────────────────────
    function deleteSelectedRows() {
        const checkedBoxes = document.querySelectorAll('.row-check:checked');
        if (checkedBoxes.length === 0) return;

        if (!confirm(`Delete ${checkedBoxes.length} selected rows from the database?`)) return;

        const indices = [];
        checkedBoxes.forEach(cb => {
            indices.push(parseInt(cb.dataset.row, 10));
        });

        const payload = { RowIndices: indices };

        fetch('@Url.Action("DeleteRows", "Csv")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) return response.json();
            throw new Error('Failed to delete selected rows.');
        })
        .then(data => {
            window.location.reload();
        })
        .catch(err => {
            alert('Error deleting rows: ' + err.message);
        });
    }

    // ── Duplicate Cleaner Tool Logic ────────────────────
    let duplicatePanelVisible = false;

    function toggleDuplicatePanel() {
        duplicatePanelVisible = !duplicatePanelVisible;
        const panel = document.getElementById('duplicatePanel');
        panel.classList.toggle('d-none', !duplicatePanelVisible);
        if (!duplicatePanelVisible) {
            document.getElementById('scanResults').classList.add('d-none');
            document.getElementById('duplicateGroupsContainer').innerHTML = '';
        }
    }

    function toggleDbCheck(id) {
        const cb = document.getElementById(id);
        if (cb) {
            cb.checked = !cb.checked;
            const div = cb.closest('.form-check');
            div.classList.toggle('border-primary', cb.checked);
            div.classList.toggle('border-light', !cb.checked);
        }
    }

    // Scan client-side DOM rows to find duplicates based on selected keys
    function scanDatabaseDuplicates() {
        const keysToUse = Array.from(document.querySelectorAll('.db-col-select:checked')).map(cb => cb.value);
        if (keysToUse.length === 0) {
            alert('Please select at least one column to match by.');
            return;
        }

        // Get table structure and rows
        const headers = [];
        document.querySelectorAll('#savedTable thead th').forEach((th, i) => {
            if (i >= 2 && i < document.querySelectorAll('#savedTable thead th').length - 1)
                headers.push(th.textContent.trim());
        });

        const groups = {}; // key -> [{ rowIdx, values, tr }]
        const trs = document.querySelectorAll('#tableBody tr');

        trs.forEach(tr => {
            if (tr.id === 'newRowTemplate') return;
            const rowIdx = parseInt(tr.dataset.row, 10);
            const cells = tr.querySelectorAll('.editable-cell');
            const rowValues = [];
            cells.forEach(c => rowValues.push(c.textContent.trim()));

            // Build key
            const keyParts = [];
            keysToUse.forEach(colName => {
                const colIdx = headers.findIndex(h => h === colName);
                if (colIdx >= 0 && colIdx < rowValues.length) {
                    keyParts.push(rowValues[colIdx].toLowerCase());
                } else {
                    keyParts.push('');
                }
            });
            const key = keyParts.join('||');

            if (!groups[key]) groups[key] = [];
            groups[key].push({
                rowIdx: rowIdx,
                values: rowValues,
                tr: tr
            });
        });

        // Filter for duplicates
        const duplicateGroups = [];
        let totalDupCount = 0;
        for (const k in groups) {
            if (groups[k].length > 1) {
                duplicateGroups.push(groups[k]);
                totalDupCount += groups[k].length;
            }
        }

        const scanResults = document.getElementById('scanResults');
        const container = document.getElementById('duplicateGroupsContainer');
        const summary = document.getElementById('scanResultsSummary');
        const deleteBtn = document.getElementById('deleteDuplicatesBtn');

        scanResults.classList.remove('d-none');
        container.innerHTML = '';

        if (duplicateGroups.length === 0) {
            summary.textContent = 'Scan Complete: No duplicates found.';
            deleteBtn.disabled = true;
            container.innerHTML = `<div class="alert alert-success py-2 px-3 small"><i class="bi bi-check-circle-fill me-1"></i> No duplicates detected with current columns.</div>`;
            return;
        }

        summary.innerHTML = `<i class="bi bi-exclamation-triangle-fill text-warning me-1"></i> Found <b>${duplicateGroups.length}</b> duplicate groups (<b>${totalDupCount}</b> rows total)`;
        deleteBtn.disabled = false;

        // Render duplicate groups
        duplicateGroups.forEach((group, gIdx) => {
            const card = document.createElement('div');
            card.className = 'card mb-2 shadow-sm border-warning';
            
            let html = `
                <div class="card-header py-1 px-3 bg-light d-flex align-items-center justify-content-between" style="font-size:0.8rem;">
                    <span class="fw-700 text-warning"><i class="bi bi-collection me-1"></i>Group #${gIdx + 1}</span>
                    <span class="small text-muted">${group.length} duplicates</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered mb-0 align-middle table-sm" style="font-size:0.82rem;">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width:75px; color:red;">DELETE</th>
                                <th class="text-center" style="width:40px;">#</th>
                                ${headers.map(h => `<th>${h}</th>`).join('')}
                            </tr>
                        </thead>
                        <tbody>
            `;

            group.forEach((item, itemIdx) => {
                // By default, check all except the first one in the group to delete, 
                // effectively keeping the first record and removing others.
                const shouldCheckToDelete = (itemIdx > 0);
                html += `
                    <tr>
                        <td class="text-center bg-danger-light">
                            <input class="form-check-input dup-delete-cb" type="checkbox" data-row="${item.rowIdx}" 
                                   ${shouldCheckToDelete ? 'checked' : ''} onchange="updateDbDupDeleteBtn()" />
                        </td>
                        <td class="text-center text-muted small">${item.rowIdx + 1}</td>
                        ${item.values.map(val => `<td>${val}</td>`).join('')}
                    </tr>
                `;
            });

            html += `
                        </tbody>
                    </table>
                </div>
            `;
            card.innerHTML = html;
            container.appendChild(card);
        });

        updateDbDupDeleteBtn();
    }

    function updateDbDupDeleteBtn() {
        const count = document.querySelectorAll('.dup-delete-cb:checked').length;
        const btn = document.getElementById('deleteDuplicatesBtn');
        btn.textContent = `Delete Selected Duplicates (${count})`;
        btn.disabled = count === 0;
    }

    function deleteSelectedDuplicates() {
        const checked = document.querySelectorAll('.dup-delete-cb:checked');
        if (checked.length === 0) return;

        if (!confirm(`Permanently delete the ${checked.length} selected duplicate row(s) from the database?`)) return;

        const indices = [];
        checked.forEach(cb => {
            indices.push(parseInt(cb.dataset.row, 10));
        });

        const payload = { RowIndices: indices };

        fetch('@Url.Action("DeleteRows", "Csv")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) return response.json();
            throw new Error('Failed to delete selected duplicates.');
        })
        .then(data => {
            window.location.reload();
        })
        .catch(err => {
            alert('Error deleting duplicates: ' + err.message);
        });
    }


    // ── Validation on Blur / Edit ───────────────────────
    function onCellBlur(el) { runCellValidation(el); }
    function onCellInput(el) { runCellValidation(el); }

    function runCellValidation(el) {
        const td = el.closest('td');
        if (!td) return;
        const val = el.textContent.trim();
        td.classList.remove('cell-invalid', 'cell-empty');
        
        if (val === '') {
            td.classList.add('cell-empty');
            return;
        }

        const colIdx = parseInt(td.dataset.col, 10);
        if (isNaN(colIdx)) return;
        
        const thList = document.querySelectorAll('#savedTable thead th');
        const th = thList[colIdx + 2]; // Offset checkbox and # index cols
        if (th) {
            const colName = th.textContent.trim().toLowerCase();
            if (colName.includes('date')) {
                if (val.includes('-')) {
                    td.classList.add('cell-invalid');
                } else {
                    const dateRegex = /^\d{1,2}\/\d{1,2}\/\d{4}$/;
                    if (!dateRegex.test(val)) {
                        td.classList.add('cell-invalid');
                    } else {
                        const parts = val.split('/');
                        const d = parseInt(parts[0], 10);
                        const m = parseInt(parts[1], 10);
                        const y = parseInt(parts[2], 10);
                        const testDate = new Date(y, m - 1, d);
                        if (testDate.getFullYear() !== y || testDate.getMonth() !== m - 1 || testDate.getDate() !== d) {
                            td.classList.add('cell-invalid');
                        }
                    }
                }
            }
        }
    }

    // ── Data Validation Panel ───────────────────────────
    let validationVisible = false;

    function toggleValidation() {
        validationVisible = !validationVisible;
        const panel = document.getElementById('validationPanel');
        if (validationVisible) {
            panel.classList.remove('d-none');
            runValidation();
        } else {
            panel.classList.add('d-none');
            // Clear highlights
            document.querySelectorAll('td.cell-empty, td.cell-invalid').forEach(td => {
                td.classList.remove('cell-empty', 'cell-invalid');
            });
        }
    }

    function runValidation() {
        const items = [];
        let issueCount = 0;
        const headers = [];
        document.querySelectorAll('#savedTable thead th').forEach((th, i) => {
            if (i >= 2 && i < document.querySelectorAll('#savedTable thead th').length - 1)
                headers.push(th.textContent.trim());
        });

        document.querySelectorAll('#tableBody tr').forEach((tr, rowIdx) => {
            if (tr.id === 'newRowTemplate') return;
            const cells = tr.querySelectorAll('td .editable-cell');
            cells.forEach((el, colIdx) => {
                const td = el.closest('td');
                const val = el.textContent.trim();
                const colName = headers[colIdx] || `Col ${colIdx + 1}`;
                td.classList.remove('cell-empty', 'cell-invalid');

                if (val === '') {
                    td.classList.add('cell-empty');
                    items.push({ type: 'warn', msg: `Row ${rowIdx + 1}, <b>${colName}</b>: empty value` });
                    issueCount++;
                } else if (colName.toLowerCase().includes('date')) {
                    if (val.includes('-')) {
                        td.classList.add('cell-invalid');
                        items.push({ type: 'danger', msg: `Row ${rowIdx + 1}, <b>${colName}</b>: Date must use '/' slashes instead of dashes` });
                        issueCount++;
                    } else {
                        const dateRegex = /^\d{1,2}\/\d{1,2}\/\d{4}$/;
                        if (!dateRegex.test(val)) {
                            td.classList.add('cell-invalid');
                            items.push({ type: 'danger', msg: `Row ${rowIdx + 1}, <b>${colName}</b>: Date format must be day/month/year (e.g. 29/06/2026)` });
                            issueCount++;
                        } else {
                            const parts = val.split('/');
                            const d = parseInt(parts[0], 10);
                            const m = parseInt(parts[1], 10);
                            const y = parseInt(parts[2], 10);
                            const testDate = new Date(y, m - 1, d);
                            if (testDate.getFullYear() !== y || testDate.getMonth() !== m - 1 || testDate.getDate() !== d) {
                                td.classList.add('cell-invalid');
                                items.push({ type: 'danger', msg: `Row ${rowIdx + 1}, <b>${colName}</b>: '${val}' is not a valid calendar date` });
                                issueCount++;
                            }
                        }
                    }
                }
            });
        });

        const invalidCountEl = document.getElementById('invalidCount');
        if (invalidCountEl) invalidCountEl.textContent = issueCount;

        const container = document.getElementById('validationItems');
        if (!container) return;
        container.innerHTML = '';

        if (items.length === 0) {
            container.innerHTML = `<div class="val-item ok"><i class="bi bi-check-circle-fill"></i> All cells have values — no issues found.</div>`;
        } else {
            items.forEach(item => {
                const div = document.createElement('div');
                div.className = `val-item ${item.type}`;
                div.innerHTML = `<i class="bi bi-${item.type === 'warn' ? 'exclamation-circle' : 'x-circle-fill'}"></i> ${item.msg}`;
                container.appendChild(div);
            });
        }
        updateVisibleCount();
    }


    // ── Search & Filter Logic ───────────────────────────
    let currentMatchIndex = -1;
    let matchedRows = [];
    const HIGHLIGHT_CLASS = 'search-highlight';
    const HIGHLIGHT_ACTIVE = 'search-highlight-active';

    function getColIndex(colName) {
        if (colName === 'all') return -1;
        let idx = -1;
        document.querySelectorAll('#savedTable thead th').forEach((th, i) => {
            if (i >= 2 && th.textContent.trim() === colName) idx = i - 2; // offset checkbox + #
        });
        return idx;
    }

    function onSearchInput(query) {
        const q = query.trim();
        const colName = document.getElementById('searchCol')?.value || 'all';
        const colIdx = getColIndex(colName);
        const clearBtn = document.getElementById('searchClear');
        const resultsBar = document.getElementById('searchResults');
        const matchBadge = document.getElementById('matchBadge');
        const icon = document.getElementById('searchIcon');

        if (clearBtn) clearBtn.classList.toggle('d-none', q === '');
        if (icon) icon.className = q ? 'bi bi-search text-accent' : 'bi bi-search';

        // Remove highlights
        document.querySelectorAll('.' + HIGHLIGHT_CLASS).forEach(el => {
            el.outerHTML = el.textContent;
        });
        matchedRows = [];
        currentMatchIndex = -1;

        if (q === '') {
            document.querySelectorAll('#tableBody tr').forEach(tr => {
                if (tr.id !== 'newRowTemplate') tr.style.display = '';
            });
            if (resultsBar) resultsBar.style.display = 'none';
            if (matchBadge) matchBadge.style.display = 'none';
            updateVisibleCount();
            return;
        }

        const ql = q.toLowerCase();
        let visible = 0;

        document.querySelectorAll('#tableBody tr').forEach(tr => {
            if (tr.id === 'newRowTemplate') return;
            const cells = tr.querySelectorAll('.editable-cell');
            let rowMatches = false;

            cells.forEach((cell, ci) => {
                if (colIdx !== -1 && ci !== colIdx) return;
                const text = cell.textContent;
                const lower = text.toLowerCase();
                const pos = lower.indexOf(ql);
                if (pos !== -1) {
                    rowMatches = true;
                    const before = text.slice(0, pos);
                    const match  = text.slice(pos, pos + q.length);
                    const after  = text.slice(pos + q.length);
                    cell.innerHTML =
                        escHtml(before) +
                        `<mark class="${HIGHLIGHT_CLASS}">${escHtml(match)}</mark>` +
                        escHtml(after);
                }
            });

            tr.style.display = rowMatches ? '' : 'none';
            if (rowMatches) { visible++; matchedRows.push(tr); }
        });

        const matchText = document.getElementById('searchMatchText');
        if (matchText) matchText.innerHTML =
            `<i class="bi bi-search me-1"></i> <b>${visible}</b> row${visible !== 1 ? 's' : ''} matched <span style="color:var(--text-muted)">"${escHtml(q)}"</span>` +
            (colIdx !== -1 ? ` <span class="badge" style="background:rgba(108,99,255,0.18);color:var(--accent);">${colName}</span>` : '');
        if (resultsBar) resultsBar.style.display = visible > 0 || q ? 'flex' : 'none';
        if (matchBadge) { matchBadge.textContent = visible + ' match' + (visible !== 1 ? 'es' : ''); matchBadge.style.display = ''; }

        if (matchedRows.length > 0) {
            currentMatchIndex = 0;
            highlightActiveRow();
        }
        updateVisibleCount(visible);
    }

    function onSearchKey(e) {
        if (e.key === 'Escape') { clearSearch(); return; }
        if (e.key === 'ArrowDown') { e.preventDefault(); stepMatch(1); }
        if (e.key === 'ArrowUp')   { e.preventDefault(); stepMatch(-1); }
    }

    function stepMatch(dir) {
        if (!matchedRows.length) return;
        matchedRows[currentMatchIndex]?.classList.remove('search-row-active');
        currentMatchIndex = (currentMatchIndex + dir + matchedRows.length) % matchedRows.length;
        highlightActiveRow();
    }

    function highlightActiveRow() {
        matchedRows.forEach(tr => tr.classList.remove('search-row-active'));
        const active = matchedRows[currentMatchIndex];
        if (active) {
            active.classList.add('search-row-active');
            active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
    }

    function clearSearch() {
        const input = document.getElementById('mainSearch');
        if (input) { input.value = ''; input.focus(); }
        onSearchInput('');
    }

    function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function updateVisibleCount(vis) {
        const total = document.querySelectorAll('#tableBody tr:not(#newRowTemplate)').length;
        const shown = vis !== undefined ? vis : total;
        const el = document.getElementById('visibleCount');
        if (el) el.textContent = `Showing ${shown} of ${total} rows`;
        const totalEl = document.getElementById('totalRowCount');
        if (totalEl) totalEl.textContent = total;
    }


    // ── Export CSV ───────────────────────────────────────
    function downloadCsv() {
        const table = document.getElementById('savedTable');
        if (!table) return;
        const csv = [];
        
        const headers = [];
        table.querySelectorAll('thead th').forEach((th, i) => {
            if (i >= 2 && i < table.querySelectorAll('thead th').length - 1) { // Skip Checkbox, # and Actions
                headers.push('"' + th.innerText.replace(/"/g, '""') + '"');
            }
        });
        csv.push(headers.join(','));

        table.querySelectorAll('#tableBody tr').forEach(tr => {
            if (tr.id === 'newRowTemplate' || tr.style.display === 'none') return;
            const row = [];
            tr.querySelectorAll('.editable-cell').forEach(el => {
                row.push('"' + el.textContent.replace(/"/g, '""') + '"');
            });
            if (row.length) csv.push(row.join(','));
        });

        const blob = new Blob([csv.join('\n')], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'database_export.csv';
        a.click();
        URL.revokeObjectURL(url);
    }

    // ── Init ─────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        updateVisibleCount();
        
        // Initial issue count
        let issues = 0;
        document.querySelectorAll('#tableBody tr').forEach(tr => {
            tr.querySelectorAll('.editable-cell').forEach(el => {
                if (el.textContent.trim() === '') issues++;
            });
        });
        const el = document.getElementById('invalidCount');
        if (el) el.textContent = issues;
    });
    </script>
}
